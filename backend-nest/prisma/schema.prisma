// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  // using default output for @prisma/client; no custom src path (safer for dist runtime)
  // moduleFormat = "cjs"
}
datasource db {
  provider = "postgresql"
}



enum Gender {
  MALE
  FEMALE
  OTHER
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  surname   String

  displayName  String?   // никнейм
  phone        String?  @unique
  birthDate    DateTime?
  gender       Gender?  @default(OTHER)
  avatarUrl    String?  

  experience    Int      @default(0)
  level         Int      @default(1)
  achievements  UserAchievement[]
  refreshToken String?
  role      Role     @default(USER)
  isInBlacklist Boolean @default(false)
  favoriteGenres Genre[]
  favoriteAuthors Author[]
  followedAuthors  Author[]       @relation("UserSubscriptions")
  favoriteBooks Book[]
  readBooks Book[] @relation("ReadBooks")
  cart Cart?
  reviews Review[]
  orders       Order[] @relation("UserOrders") // Заказы самого юзера
  issuedOrders Order[] @relation("LibrarianOrders") // Заказы, которые этот юзе
  notifications Notification[]
  

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@map("users")
}

model Cart {
  id String @id @default(uuid())
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String @unique
  items CartItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@map("carts")
}

model Review {
  id String @id @default(uuid())
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String
  book Book @relation(fields: [bookId], references: [id])
  bookId String
  description String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@unique([userId, bookId])
  @@map("reviews")
}

model Notification {
  id String @id @default(uuid())
  user User @relation(fields: [userId], references: [id])
  userId String
  message String
  isViewed Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@map("notifications")
}

model Book {
  id String @id @default(uuid())
  title String
  author Author @relation(fields: [authorId], references: [id])
  authorId String
  genre Genre @relation(fields: [genreId], references: [id])
  genreId String
  reviews Review[]
  availableQuantity Int @default(0)
  cartItems CartItem[]
  orderItems OrderItem[]
  favoriteFor User[]
  readBy User[] @relation("ReadBooks")
  description String?                   
  subjects String[]                     
  publisher String?                      
  publishedDate DateTime?                
  pageCount Int?                         
  language String?                       
  coverImage String?     
  recommendedBooks Book[] @relation("BookRecommendations")
  recommendedBy Book[] @relation("BookRecommendations")
  collections Collection[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@map("books")
}


model Collection {
  id          String   @id @default(uuid())
  title       String   
  slug        String   @unique 
  description String?
  order       Int      @default(0) 
  isActive    Boolean  @default(true)
  
  books       Book[] 

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("collections")
}


model Author {
  id String @id @default(uuid())
  firstName String
  lastName String
  dateOfBirth DateTime
  dateOfDeath DateTime?
  books Book[]
  favoriteFor User[]
  followers   User[]    @relation("UserSubscriptions") 
  photoUrl    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@unique([firstName, lastName, dateOfBirth])
  @@map("authors")
}

model Genre {
  id String @id @default(uuid())
  label String
  value String @unique
  books Book[]
  users User[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@map("genres")
}

model Order {
  id            String      @id @default(uuid())
  user          User        @relation("UserOrders", fields: [userId], references: [id])
  userId        String
  
  items         OrderItem[]
  status        OrderStatus @default(PENDING)
  
  pickupCode    String?     @unique 
  
  issuedById    String?
  issuedBy      User?       @relation("LibrarianOrders", fields: [issuedById], references: [id])
  
  orderDate     DateTime    @default(now())
  dueDate       DateTime    // Когда нужно вернуть
  returnDate    DateTime?   
  
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  @@map("orders")
}

model CartItem {
  id String @id @default(uuid())
  cart Cart @relation(fields: [cartId], references: [id], onDelete: Cascade)
  cartId String
  book Book @relation(fields: [bookId], references: [id])
  bookId String
  quantity Int @default(1)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@unique([cartId, bookId])
  @@map("cart_items")
}

model OrderItem {
  id String @id @default(uuid())
  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId String
  book Book @relation(fields: [bookId], references: [id])
  bookId String
  quantity Int @default(1)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@map("order_items")
}

model Achievement {
  id          String   @id @default(uuid())
  title       String  @unique  // "Книжный червь"
  description String   // "Прочитайте 10 книг"
  icon        String   // Эмодзи или код иконки
  
  category    AchievementCategory @default(READING)
  
  targetValue Int      // Сколько нужно выполнить (например, 10)
  rewardExp   Int      // Сколько XP даем за выполнение
  
  users       UserAchievement[]

  createdAt   DateTime @default(now())
  @@map("achievements")
}

model UserAchievement {
  id            String   @id @default(uuid())
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId        String
  achievement   Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)
  achievementId String
  
  currentValue  Int      @default(0) // Текущий прогресс юзера (например, прочитал 4 из 10)
  isCompleted   Boolean  @default(false)
  completedAt   DateTime?

  @@unique([userId, achievementId])
  @@map("user_achievements")
}

// Конфиг уровней (Ранги)
model LevelConfig {
  level      Int    @id // 1, 2, 3...
  minExp     Int    // Сколько нужно XP для этого уровня
  title      String // "Новичок", "Читатель", "Магистр"
  
  @@map("level_config")
}

enum AchievementCategory {
  READING   // За чтение
  SOCIAL    // За отзывы и активность
  SYSTEM    // За стаж регистрации, профиль и т.д.
}


enum Role {
  LIBRARIAN
  USER
}

enum OrderStatus {
  PENDING
  APPROVED      // Библиотекарь одобрил заявку
  READY_TO_PICKUP // Библиотекарь ввел код, книги перед ним на столе
  ON_HAND       // Пользователь подтвердил получение в приложении
  OVERDUE
  RETURNED
  CANCELLED
}